---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE, ZALO_LINK } from '../consts';
import { Image } from 'astro:assets';

import heroImage from '../assets/hung/image.png';
import vtvImage from '../assets/hung/image-1.png';
import trainingImage from '../assets/hung/image-3.png';
import communityImage from '../assets/hung/IMG_5224.JPG';
import investorMeetingImage from '../assets/hung/586553226_1420907506707485_5494408194781805438_n.jpg';
import bniImage from '../assets/hung/5b41c281-ee87-4477-b408-ead35a5bca8f.png';
import activity4 from '../assets/hung/activity-4.jpg';
import activity5 from '../assets/hung/activity-5.jpg';
import activity6 from '../assets/hung/activity-6.jpg';
---

<!doctype html>
<html lang="vi">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
		<style>
			:root {
				--ssi-blue: #005595;
				--charcoal: #333333;
				--white: #ffffff;
				--spacing-hero: 10rem;
				--spacing-section: 8rem;
				--spacing-medium: 4rem;
				--spacing-small: 2rem;
			}

			body {
				background-color: var(--white);
				color: var(--charcoal);
				font-family: 'Open Sans', -apple-system, BlinkMacSystemFont, sans-serif;
				line-height: 1.6;
			}

			main {
				max-width: 100%;
				margin: 0 auto;
				padding: 0;
			}

			section {
				padding: var(--spacing-section) var(--spacing-small);
				text-align: center;
				display: flex;
				flex-direction: column;
				align-items: center;
			}

			#hero {
				padding-top: var(--spacing-hero);
				background-color: var(--white);
			}

			h1, h2 {
				font-family: 'Montserrat', sans-serif;
				font-weight: 700;
				color: var(--charcoal);
				margin-bottom: var(--spacing-small);
				letter-spacing: -0.04em;
				max-width: 800px;
			}

			h1 {
				font-size: 4rem;
				line-height: 1.05;
			}

			h2 {
				font-size: 2.5rem;
				line-height: 1.2;
			}

			.intro-text {
				font-size: 1.5rem;
				color: var(--charcoal);
				max-width: 700px;
				margin: 0 auto var(--spacing-medium);
				font-weight: 400;
				opacity: 0.9;
			}

			.accent-text {
				color: var(--ssi-blue);
				font-weight: 600;
			}

			.featured-quote {
				background: #fdfdfd;
				padding: var(--spacing-medium) var(--spacing-small);
				width: 100%;
				display: flex;
				justify-content: center;
				border-top: 1px solid #f0f0f0;
				border-bottom: 1px solid #f0f0f0;
			}

			.lua-hoa-box {
				max-width: 800px;
			}

			.lua-hoa-box blockquote {
				border-left: none;
				padding: 0;
				margin: 0;
				font-size: 1.85rem;
				font-style: italic;
				color: var(--ssi-blue);
				line-height: 1.4;
				font-family: 'Montserrat', sans-serif;
				font-weight: 600;
			}

			.feature-grid {
				display: grid;
				grid-template-columns: repeat(3, 1fr);
				gap: var(--spacing-medium);
				max-width: 1000px;
				width: 100%;
				margin-top: var(--spacing-medium);
				text-align: center;
			}

			.feature-card {
				padding: var(--spacing-small);
			}

			.feature-card h3 {
				color: var(--ssi-blue);
				font-size: 1.25rem;
				margin-bottom: 1rem;
				font-weight: 700;
				text-transform: uppercase;
				letter-spacing: 0.05em;
			}

			.feature-card p {
				font-size: 1rem;
				color: #666;
				line-height: 1.5;
			}

			.cta-button {
				display: inline-block;
				margin-top: var(--spacing-small);
				padding: 1.25rem 2.5rem;
				background-color: var(--ssi-blue);
				color: var(--white);
				text-decoration: none;
				font-weight: 600;
				font-size: 1.1rem;
				border-radius: 100px; /* Apple-like rounded pill */
				transition: all 0.3s ease;
				box-shadow: 0 4px 14px 0 rgba(0, 85, 149, 0.2);
			}

			.cta-button:hover {
				transform: translateY(-2px);
				box-shadow: 0 6px 20px rgba(0, 85, 149, 0.25);
				opacity: 0.95;
				color: var(--white);
			}

			.cta-button.secondary {
				background-color: #25d366; /* Zalo/WhatsApp green */
				box-shadow: 0 4px 14px 0 rgba(37, 211, 102, 0.2);
			}

			.cta-button.secondary:hover {
				box-shadow: 0 6px 20px rgba(37, 211, 102, 0.25);
			}

			.hero-image {
				width: 200px;
				height: 200px;
				border-radius: 50%;
				object-fit: cover;
				margin-bottom: var(--spacing-small);
				border: 4px solid #f8f9fa;
				box-shadow: 0 10px 30px rgba(0,0,0,0.1);
			}

			.proof-section {
				background-color: #ffffff;
				width: 100%;
			}

			.proof-image {
				max-width: 800px;
				width: 100%;
				height: auto;
				border-radius: 12px;
				box-shadow: 0 8px 30px rgba(0,0,0,0.05);
				margin-top: var(--spacing-medium);
			}

			.activity-grid {
				display: grid;
				grid-template-columns: repeat(3, 1fr);
				gap: var(--spacing-medium);
				max-width: 1200px;
				width: 100%;
				margin-top: var(--spacing-medium);
			}

			.activity-item {
				text-align: center;
			}

			.activity-item .image-wrapper {
				width: 100%;
				aspect-ratio: 3 / 2;
				overflow: hidden;
				border-radius: 12px;
				margin-bottom: 1rem;
				box-shadow: 0 4px 15px rgba(0,0,0,0.05);
			}

			.activity-item img {
				width: 100%;
				height: 100%;
				object-fit: cover;
				transition: transform 0.6s cubic-bezier(0.165, 0.84, 0.44, 1);
			}

			.activity-item:hover img {
				transform: scale(1.08);
			}

			.activity-item p {
				font-size: 0.95rem;
				color: #555;
				font-weight: 500;
				line-height: 1.4;
			}

			@media (max-width: 900px) {
				.feature-grid, .activity-grid {
					grid-template-columns: 1fr;
					gap: var(--spacing-small);
				}
				
				h1 {
					font-size: 3rem;
				}
				
				.intro-text {
					font-size: 1.25rem;
				}
			}

			@media (max-width: 600px) {
				:root {
					--spacing-hero: 6rem;
					--spacing-section: 4rem;
				}
				
				h1 {
					font-size: 2.5rem;
				}
				
				h2 {
					font-size: 1.75rem;
				}
				
				.lua-hoa-box blockquote {
					font-size: 1.4rem;
				}
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<section id="hero">
				<Image src={heroImage} alt="Nguyễn Việt Hùng - Lúa Hóa Chứng Khoán" class="hero-image" width={200} height={200} />
				<h1>Lúa Hóa Chứng Khoán</h1>
				<p class="intro-text">
					Xin chào, tôi là <span class="accent-text">Nguyễn Việt Hùng</span>.<br/>
					Trưởng phòng Tư vấn Đầu tư tại SSI.
				</p>
				<p style="max-width: 600px; color: #666;">
					Với kinh nghiệm thực chiến trên thị trường, tôi mang đến góc nhìn minh triết và thấu cảm để đồng hành cùng bạn trên hành trình nuôi dưỡng tài sản bền vững.
				</p>
				<div style="display: flex; gap: 1rem; flex-wrap: wrap; justify-content: center;">
					<a href="/contact" class="cta-button">Liên hệ tư vấn</a>
					<a href={ZALO_LINK} class="cta-button secondary" target="_blank" rel="noopener noreferrer">Kết nối Zalo</a>
				</div>
			</section>

			<section class="featured-quote">
				<div class="lua-hoa-box">
					<blockquote>
						"Cũng như cây lúa cần thời gian để trổ bông và chín vàng, đầu tư chứng khoán đòi hỏi sự kiên nhẫn, am hiểu quy luật tự nhiên và một tâm thế vững vàng."
					</blockquote>
				</div>
			</section>

			<section id="philosophy">
				<h2>Triết lý Đầu tư</h2>
				<div class="feature-grid">
					<div class="feature-card">
						<h3>Minh triết</h3>
						<p>Hiểu rõ bản chất doanh nghiệp và nắm bắt xu hướng vĩ mô để đưa ra quyết định dựa trên nền tảng vững chắc.</p>
					</div>
					<div class="feature-card">
						<h3>Thấu cảm</h3>
						<p>Chia sẻ thăng trầm cùng nhà đầu tư dựa trên những trải nghiệm thực tế và sự thấu hiểu sâu sắc thị trường.</p>
					</div>
					<div class="feature-card">
						<h3>Thực chiến</h3>
						<p>Những bài học quý giá được đúc kết từ hàng ngàn giờ giao dịch trực tiếp, không chỉ là lý thuyết suông.</p>
					</div>
				</div>
			</section>

			<section id="story" class="proof-section">
				<h2>Đồng hành cùng VTV Money</h2>
				<p style="max-width: 600px; color: #666;">
					Chia sẻ kiến thức và nhận định thị trường trên các kênh truyền thông chính thống, giúp nhà đầu tư có cái nhìn khách quan và chính xác.
				</p>
				<Image src={vtvImage} alt="Nguyễn Việt Hùng trên VTV Money" class="proof-image" width={800} height={450} />
			</section>

			<section id="services" style="background-color: #fafafa;">
				<h2>Dịch vụ Tư vấn SSI</h2>
				<p style="max-width: 600px; color: #666; margin-bottom: var(--spacing-medium);">
					Tận tâm hỗ trợ nhà đầu tư thông qua các giải pháp chuyên nghiệp và cá nhân hóa.
				</p>
				<div class="feature-grid">
					<div class="feature-card">
						<h3>Tư vấn Đầu tư SSI</h3>
						<p>Đồng hành cùng nhà đầu tư thiết kế danh mục tối ưu, bám sát diễn biến thị trường và tận dụng lợi thế từ hệ thống phân tích hàng đầu của SSI.</p>
					</div>
					<div class="feature-card">
						<h3>Quản trị Tài sản (NAV lớn)</h3>
						<p>Giải pháp quản lý tài sản chuyên biệt dành cho khách hàng ưu tú, tập trung vào sự bền vững, bảo mật và tối ưu hóa lợi nhuận.</p>
					</div>
					<div class="feature-card">
						<h3>Đào tạo Chứng khoán Thực chiến</h3>
						<p>Chương trình huấn luyện từ cơ bản đến nâng cao, tập trung vào kỹ năng thực chiến, tâm lý giao dịch và phương pháp "Lúa Hóa".</p>
					</div>
				</div>
			</section>

			<section id="achievements">
				<h2>Thành tựu & Hoạt động</h2>
				<div class="activity-grid">
					<div class="activity-item">
						<div class="image-wrapper">
							<Image src={trainingImage} alt="Giảng viên đào tạo tại các sự kiện lớn" width={400} height={267} />
						</div>
						<p>Giảng viên đào tạo tại các sự kiện lớn</p>
					</div>
					<div class="activity-item">
						<div class="image-wrapper">
							<Image src={communityImage} alt="Hoạt động cộng đồng và kết nối doanh nghiệp" width={400} height={267} />
						</div>
						<p>Hoạt động cộng đồng và kết nối doanh nghiệp</p>
					</div>
					<div class="activity-item">
						<div class="image-wrapper">
							<Image src={investorMeetingImage} alt="Gặp gỡ và chia sẻ cùng các nhà đầu tư" width={400} height={267} />
						</div>
						<p>Gặp gỡ và chia sẻ cùng các nhà đầu tư</p>
					</div>
					<div class="activity-item">
						<div class="image-wrapper">
							<Image src={activity4} alt="Phân tích thị trường cùng đồng nghiệp" width={400} height={267} />
						</div>
						<p>Phân tích thị trường cùng đồng nghiệp</p>
					</div>
					<div class="activity-item">
						<div class="image-wrapper">
							<Image src={activity5} alt="Chia sẻ kiến thức tại cộng đồng nhà đầu tư" width={400} height={267} />
						</div>
						<p>Chia sẻ kiến thức tại cộng đồng nhà đầu tư</p>
					</div>
					<div class="activity-item">
						<div class="image-wrapper">
							<Image src={activity6} alt="Khoảnh khắc kết nối và phát triển" width={400} height={267} />
						</div>
						<p>Khoảnh khắc kết nối và phát triển</p>
					</div>
				</div>
			</section>

			<section id="connect">
				<h2>Cùng xây dựng cộng đồng</h2>
				<p style="max-width: 600px; color: #666;">
					Kiến thức và kinh nghiệm chỉ thực sự có giá trị khi được lan tỏa. Theo dõi tôi trên Zalo để nhận bản tin thị trường hàng ngày và những góc nhìn thực chiến.
				</p>
				<Image src={bniImage} alt="Nguyễn Việt Hùng tại BNI" class="proof-image" style="margin-bottom: var(--spacing-medium);" width={800} height={450} />
				<div style="display: flex; gap: 1rem; flex-wrap: wrap; justify-content: center;">
					<a href="https://blog.hocchungkhoan.com.vn" class="cta-button" target="_blank" rel="noopener noreferrer">Khám phá Blog của tôi</a>
					<a href={ZALO_LINK} class="cta-button secondary" target="_blank" rel="noopener noreferrer">Nhận bản tin Zalo</a>
				</div>
			</section>
		</main>
		<Footer />
	</body>
</html>
