---
/**
 * Footer with Vietnamese company info
 */
import { COMPANY_NAME, COMPANY_EMAIL, COMPANY_PHONE, COMPANY_TAGLINE } from '../consts';
import { getPath } from '../utils/paths';

const currentYear = new Date().getFullYear();

const footerLinks = [
	{
		title: 'Dịch vụ',
		links: [
			{ href: '/#services', label: 'Tư vấn Đầu tư SSI' },
			{ href: '/#services', label: 'Quản trị Tài sản (NAV lớn)' },
			{ href: '/#services', label: 'Đào tạo Chứng khoán Thực chiến' },
		]
	},
	{
		title: 'Công ty',
		links: [
			{ href: '/about', label: 'Về chúng tôi' },
			{ href: 'https://blog.hocchungkhoan.com.vn', label: 'Blog', target: '_blank', rel: 'noopener noreferrer' },
			{ href: '/contact', label: 'Liên hệ' },
		]
	}
];

const socialLinks = [
	{ href: 'https://www.facebook.com/hungnv1203/', label: 'Facebook', icon: 'facebook' },
	{ href: 'https://www.youtube.com/@viethungluahoa', label: 'YouTube', icon: 'youtube' },
];
---

<footer>
	<div class="footer-container container">
		<div class="footer-main">
			<div class="footer-brand">
				<h3 class="footer-logo">{COMPANY_NAME}</h3>
				<p class="footer-tagline">{COMPANY_TAGLINE}</p>
				<div class="footer-contact">
					<a href={`mailto:${COMPANY_EMAIL}`}>{COMPANY_EMAIL}</a>
					<a href={`tel:${COMPANY_PHONE.replace(/\s/g, '')}`}>{COMPANY_PHONE}</a>
				</div>
			</div>

			{footerLinks.map((section) => (
				<div class="footer-section">
					<h4 class="footer-section-title">{section.title}</h4>
					<ul class="footer-links">
						{section.links.map((link) => (
							<li>
								<a href={getPath(link.href)} target={link.target} rel={link.rel}>{link.label}</a>
							</li>
						))}
					</ul>
				</div>
			))}
		</div>

		<div class="footer-bottom">
			<p class="copyright">
				&copy; {currentYear} {COMPANY_NAME}. Đã đăng ký bản quyền.
			</p>
			<div class="social-links">
				{socialLinks.map((social) => (
					<a
						href={social.href}
						target="_blank"
						rel="noopener noreferrer"
						aria-label={social.label}
					>
						{social.icon === 'facebook' && (
							<svg viewBox="0 0 24 24" width="20" height="20" aria-hidden="true">
								<path fill="currentColor" d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
							</svg>
						)}
						{social.icon === 'youtube' && (
							<svg viewBox="0 0 24 24" width="20" height="20" aria-hidden="true">
								<path fill="currentColor" d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.016 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.016 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/>
							</svg>
						)}
					</a>
				))}
			</div>
		</div>
	</div>
</footer>

<style>
	footer {
		background: var(--color-neutral-900);
		color: var(--color-neutral-300);
		padding: var(--space-16) 0 var(--space-8);
	}

	.footer-container {
		max-width: var(--container-xl);
		margin: 0 auto;
		padding: 0 var(--section-padding-x);
	}

	.footer-main {
		display: grid;
		grid-template-columns: 2fr 1fr 1fr;
		gap: var(--space-12);
		padding-bottom: var(--space-12);
		border-bottom: 1px solid var(--color-neutral-700);
	}

	.footer-logo {
		font-family: var(--font-heading);
		font-size: var(--text-2xl);
		color: var(--color-white);
		margin: 0 0 var(--space-2) 0;
	}

	.footer-tagline {
		font-size: var(--text-base);
		color: var(--color-neutral-400);
		margin: 0 0 var(--space-6) 0;
	}

	.footer-contact {
		display: flex;
		flex-direction: column;
		gap: var(--space-2);
	}

	.footer-contact a {
		color: var(--color-neutral-300);
		text-decoration: none;
		font-size: var(--text-sm);
		transition: color var(--transition-fast);
	}

	.footer-contact a:hover {
		color: var(--color-primary-light);
	}

	.footer-section-title {
		font-family: var(--font-heading);
		font-size: var(--text-base);
		font-weight: var(--font-semibold);
		color: var(--color-white);
		margin: 0 0 var(--space-4) 0;
	}

	.footer-links {
		list-style: none;
		margin: 0;
		padding: 0;
		display: flex;
		flex-direction: column;
		gap: var(--space-3);
	}

	.footer-links a {
		color: var(--color-neutral-400);
		text-decoration: none;
		font-size: var(--text-sm);
		transition: color var(--transition-fast);
	}

	.footer-links a:hover {
		color: var(--color-white);
	}

	.footer-bottom {
		display: flex;
		justify-content: space-between;
		align-items: center;
		padding-top: var(--space-8);
	}

	.copyright {
		font-size: var(--text-sm);
		color: var(--color-neutral-500);
		margin: 0;
	}

	.social-links {
		display: flex;
		gap: var(--space-4);
	}

	.social-links a {
		color: var(--color-neutral-400);
		transition: color var(--transition-fast);
	}

	.social-links a:hover {
		color: var(--color-white);
	}

	/* Responsive */
	@media (max-width: 768px) {
		.footer-main {
			grid-template-columns: 1fr;
			gap: var(--space-8);
		}

		.footer-bottom {
			flex-direction: column;
			gap: var(--space-4);
			text-align: center;
		}
	}

	/* Reduced motion */
	@media (prefers-reduced-motion: reduce) {
		.footer-contact a,
		.footer-links a,
		.social-links a {
			transition: none;
		}
	}
</style>
